# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# AI provider selector: "groq" (default, hosted, always-on) or "ollama" (local LLM).
# Production runs on Groq with no machine to keep up. Set AI_PROVIDER=ollama only
# if you want to run against your local Ollama (e.g. offline dev). Everything for
# both backends stays configured below, so you switch by flipping this one value.
AI_PROVIDER=groq

# AI (Ollama — local LLM server; no API key required)
# Local dev: leave as localhost. In production the deployed app cannot reach your
# machine, so point this at your machine's Ollama exposed via a Cloudflare Tunnel,
# e.g. OLLAMA_BASE_URL=https://ollama.yourdomain.com  (your machine must stay on).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# GPU layers to offload. Set to 0 to run fully on CPU when the model doesn't fit
# in VRAM (e.g. an 8B model on a 4 GB GPU → "cudaMalloc out of memory"). Leave
# unset to let Ollama auto-decide on a GPU with enough memory.
OLLAMA_NUM_GPU=0
# Cloudflare Access service-token credentials that lock down the public tunnel.
# Set BOTH only in production (Vercel); leave blank for local dev. Create them in
# Cloudflare Zero Trust → Access → Service Auth.
OLLAMA_ACCESS_CLIENT_ID=
OLLAMA_ACCESS_CLIENT_SECRET=

# AI (Groq — hosted, OpenAI-compatible fallback; only used when AI_PROVIDER=groq)
# Get a key at https://console.groq.com/keys. GROQ_MODEL defaults to a strong
# hosted Llama; GROQ_BASE_URL lets this adapter target any OpenAI-shaped endpoint
# (OpenRouter / Together / Fireworks) without code changes.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Payments (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Gmail SMTP via nodemailer)
# GMAIL_USER: your full Gmail address.
# GMAIL_APP_PASSWORD: a 16-char App Password (Google Account → Security →
#   2-Step Verification → App passwords). NOT your normal login password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional display name shown to recipients.
EMAIL_FROM_NAME=AI Invention Registry

# Background jobs (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
