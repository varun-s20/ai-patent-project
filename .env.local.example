# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# AI (Ollama — local LLM server; no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# GPU layers to offload. Set to 0 to run fully on CPU when the model doesn't fit
# in VRAM (e.g. an 8B model on a 4 GB GPU → "cudaMalloc out of memory"). Leave
# unset to let Ollama auto-decide on a GPU with enough memory.
OLLAMA_NUM_GPU=0

# Payments (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Background jobs (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
