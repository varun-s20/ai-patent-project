# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all real env files (they hold secrets)...
.env*
# ...but keep the documented template tracked (no secrets in it).
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project docs & AI tooling — kept local, not part of the shipping codebase
# (Supabase migrations under supabase/ stay tracked — they're needed for account migration)
*.docx
AGENTS.md
CLAUDE.md
.claude/
docs/
